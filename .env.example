# V-Stock Radar 配置文件
# 复制此文件为 .env 并根据需要修改

# 数据库配置
DATABASE_URL_SYNC=sqlite:///./data/vstock.db

# 爬虫配置
USE_MOCK_DATA=true
SCRAPER_DELAY_MIN=2.0
SCRAPER_DELAY_MAX=5.0

# 服务端口
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Playwright 浏览器自动化
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000

# 调试模式
DEBUG=false
