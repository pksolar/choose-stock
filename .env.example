# V-Stock Radar 配置文件
# 复制此文件为 .env 并根据需要修改

# 数据库配置
DATABASE_URL_SYNC=sqlite:///./data/vstock.db

# Redis 配置
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# 爬虫配置
USE_MOCK_DATA=true
SCRAPER_DELAY_MIN=2.0
SCRAPER_DELAY_MAX=5.0

# 服务端口
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Playwright 浏览器自动化
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
BROWSER_USE_CDP=false
BROWSER_CDP_ENDPOINT=http://localhost:9222

# 调试模式
DEBUG=false
